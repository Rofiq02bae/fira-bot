# ── Host Paths (untuk docker-compose volume mount) ───────
VENV_PATH=./.venv
DATA_PATH=./data
# Pakai absolute path, bukan ~ (tilde tidak selalu di-expand)
HF_CACHE_PATH=/home/YOUR_USERNAME/.cache/huggingface

# ── Telegram ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=isi_token_bot_anda

# ── Model Paths (di dalam container) ─────────────────────
DATASET_PATH=/data/dataset/dataset_training.csv
LSTM_MODEL_PATH=/data/lstm_models/chatbot_model.h5
LSTM_TOKENIZER_PATH=/data/lstm_models/tokenizer.pkl
LSTM_LABEL_ENCODER_PATH=/data/lstm_models/label_encoder.pkl
BERT_MODEL_PATH=/data/bert_model

# ── RAG ──────────────────────────────────────────────────
USE_RAG=true
FAISS_INDEX_PATH=/data/rag/faiss.index
FAISS_METADATA_PATH=/data/rag/metadata.pkl
SIMILARITY_THRESHOLD=0.3
TOP_K_DOCUMENTS=5

# ── LLM (OpenRouter) ─────────────────────────────────────
LLM_PROVIDER=openrouter
LLM_API_KEY=sk-or-v1-xxxxxxxxxx
LLM_MODEL=google/gemini-2.0-flash-exp:free
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=500

# ── API ──────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=False


# --- docker personal access token untuk private repo (jika diperlukan) ---
DOCKER_USERNAME=usrnme
DOCKER_PAT=dckr_pat_-----