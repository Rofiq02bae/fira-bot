# RAG Configuration Example
# Copy this to .env and fill in your values
TELEGRAM_BOT_TOKEN=token-Telegram
# Enable RAG
USE_RAG=true

# FAISS Vector Store
FAISS_INDEX_PATH=data/rag/faiss.index
FAISS_METADATA_PATH=data/rag/metadata.pkl
SIMILARITY_THRESHOLD=0.3
TOP_K_DOCUMENTS=5

# OpenRouter LLM Configuration
LLM_PROVIDER=openrouter
LLM_API_KEY=sk-or-v1-your-api-key-here
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=google/gemini-2.0-flash-exp:free
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=500

# RAG Behavior
RAG_MIN_CONFIDENCE=0.4
USE_RAG_FOR_FALLBACK=true

# Other Models Available:
# LLM_MODEL=meta-llama/llama-3.2-3b-instruct:free
# LLM_MODEL=mistralai/mistral-7b-instruct:free
# LLM_MODEL=openai/gpt-4-turbo  # Paid
# LLM_MODEL=anthropic/claude-3-opus  # Paid

# --- docker personal access token untuk private repo (jika diperlukan) ---
DOCKER_USERNAME=usrnme
DOCKER_PAT=dckr_pat_-----